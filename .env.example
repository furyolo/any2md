ANY2MD_LLM_API_BASE=https://api.openai.com/v1
ANY2MD_LLM_API_KEY=sk-your-api-key
ANY2MD_LLM_MODEL=gpt-4.1-mini

# 支持 OpenAI 和 Anthropic API / Supports both OpenAI and Anthropic APIs
# OpenAI 示例 / OpenAI example:
#   ANY2MD_LLM_API_BASE=https://api.openai.com/v1
#   ANY2MD_LLM_MODEL=gpt-4o-mini
# Anthropic 示例 / Anthropic example:
#   ANY2MD_LLM_API_BASE=https://api.anthropic.com/v1
#   ANY2MD_LLM_MODEL=claude-3-5-sonnet-20241022
# 自动检测 API 类型，无需额外配置 / API type is auto-detected

# 可选 / Optional：手动指定 API 类型（当自动检测失败时）
# Manually specify API type (when auto-detection fails)
# ANY2MD_LLM_API_TYPE=anthropic  # 可选值 / Options: "openai" or "anthropic"

# 可选 / Optional：请求超时时间，单位秒
# Timeout for OCR requests, in seconds
ANY2MD_LLM_TIMEOUT=60

# 可选 / Optional：覆盖默认 OCR 提示词
# Override the default OCR prompt when you need stricter formatting guidance.
# ANY2MD_OCR_PROMPT=请识别图片中的文字并按原始版式整理成 Markdown，仅返回 Markdown 正文。

# AUC (Audio Transcription) Configuration
ANY2MD_AUC_APP_ID=your-app-id
ANY2MD_AUC_ACCESS_KEY=your-access-key
ANY2MD_AUC_RESOURCE_ID=volc.seedasr.auc
ANY2MD_AUC_SUBMIT_URL=https://openspeech.bytedance.com/api/v3/auc/bigmodel/submit
ANY2MD_AUC_QUERY_URL=https://openspeech.bytedance.com/api/v3/auc/bigmodel/query
ANY2MD_AUC_TIMEOUT=30
ANY2MD_AUC_POLL_INTERVAL=1.0
ANY2MD_AUC_MAX_WAIT_SECONDS=300

# 本地 Qwen3-ASR 配置（官方 qwen-asr 默认方案）
# 可直接填写官方模型 ID；首次运行会自动下载模型
# ANY2MD_QWEN_AUDIO_RUNTIME=qwen-asr
# ANY2MD_QWEN_AUDIO_MODEL=D:/Coding/models/Qwen3-ASR-1.7B
# ANY2MD_QWEN_AUDIO_LANGUAGE=auto
# ANY2MD_QWEN_AUDIO_TIMEOUT=3600
# ANY2MD_QWEN_AUDIO_DEVICE_MAP=cpu
# ANY2MD_QWEN_AUDIO_DTYPE=float32
# ANY2MD_QWEN_AUDIO_MAX_NEW_TOKENS=256
# ANY2MD_QWEN_AUDIO_MAX_BATCH_SIZE=1
# ANY2MD_QWEN_AUDIO_PROMPT=请逐字转写这段音频内容，只输出转写结果，不要添加解释或额外说明。

# 可选 / Optional：长音频自动切分时长（秒），默认 600（10 分钟）
# Chunk duration for long audio files, in seconds. Default is 600 (10 minutes).
# ANY2MD_QWEN_CHUNK_DURATION=600

# 可选：仅在使用 chatllm.cpp / llama.cpp 等实验性运行时时需要
# ANY2MD_QWEN_AUDIO_EXECUTABLE=D:/Coding/models/chatllm_win_x64/bin/main.exe
# ANY2MD_QWEN_AUDIO_COMMAND_TEMPLATE="{executable}" -m "{model}" --audio "{audio}" --prompt "{prompt}"
