ANY2MD_LLM_API_BASE=https://api.openai.com/v1
ANY2MD_LLM_API_KEY=sk-your-api-key
ANY2MD_LLM_MODEL=gpt-4.1-mini

# 可选 / Optional：请求超时时间，单位秒
# Timeout for OCR requests, in seconds
ANY2MD_LLM_TIMEOUT=60

# 可选 / Optional：覆盖默认 OCR 提示词
# Override the default OCR prompt when you need stricter formatting guidance.
# ANY2MD_OCR_PROMPT=请识别图片中的文字并按原始版式整理成 Markdown，仅返回 Markdown 正文。

# AUC (Audio Transcription) Configuration
ANY2MD_AUC_APP_ID=your-app-id
ANY2MD_AUC_ACCESS_KEY=your-access-key
ANY2MD_AUC_RESOURCE_ID=volc.seedasr.auc
ANY2MD_AUC_SUBMIT_URL=https://openspeech.bytedance.com/api/v3/auc/bigmodel/submit
ANY2MD_AUC_QUERY_URL=https://openspeech.bytedance.com/api/v3/auc/bigmodel/query
ANY2MD_AUC_TIMEOUT=30
ANY2MD_AUC_POLL_INTERVAL=1.0
ANY2MD_AUC_MAX_WAIT_SECONDS=300
